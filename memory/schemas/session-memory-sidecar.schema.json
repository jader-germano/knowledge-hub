{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://jpglabs.local/docs/memory/schemas/session-memory-sidecar.schema.json",
  "title": "JPGLabs Session Memory Sidecar",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "$schema",
    "schema_version",
    "session",
    "projects",
    "artifacts"
  ],
  "properties": {
    "$schema": {
      "type": "string"
    },
    "schema_version": {
      "const": "1.0"
    },
    "session": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "timestamp",
        "date",
        "provider",
        "workspace",
        "status",
        "summary"
      ],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "timestamp": {
          "type": "string",
          "format": "date-time"
        },
        "date": {
          "type": "string",
          "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
        },
        "provider": {
          "type": "string",
          "minLength": 1
        },
        "workspace": {
          "type": "string",
          "minLength": 1
        },
        "status": {
          "type": "string",
          "enum": [
            "completed",
            "partial",
            "blocked"
          ]
        },
        "feature_id": {
          "type": "string"
        },
        "summary": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "projects": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "name",
          "path"
        ],
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1
          },
          "name": {
            "type": "string",
            "minLength": 1
          },
          "path": {
            "type": "string",
            "minLength": 1
          },
          "role": {
            "type": "string"
          }
        }
      }
    },
    "artifacts": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "report",
        "daily"
      ],
      "properties": {
        "report": {
          "type": "string",
          "minLength": 1
        },
        "daily": {
          "type": "string",
          "minLength": 1
        },
        "evidence_dir": {
          "type": "string"
        }
      }
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    },
    "decisions": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/named_record"
      }
    },
    "findings": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/named_record"
      }
    },
    "next_actions": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/named_record"
      }
    },
    "files_touched": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    },
    "commands": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "command",
          "action",
          "result"
        ],
        "properties": {
          "command": {
            "type": "string",
            "minLength": 1
          },
          "action": {
            "type": "string",
            "minLength": 1
          },
          "result": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    }
  },
  "$defs": {
    "named_record": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "summary"
      ],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "summary": {
          "type": "string",
          "minLength": 1
        },
        "status": {
          "type": "string"
        },
        "rationale": {
          "type": "string"
        },
        "project_ids": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "uniqueItems": true
        }
      }
    }
  }
