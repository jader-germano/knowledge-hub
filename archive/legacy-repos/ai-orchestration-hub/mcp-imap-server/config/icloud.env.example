# iCloud Mail — MCP IMAP Server configuration
# Copy this file to .env and fill in your values.
# NEVER commit .env or any file with real credentials to version control.

# ── Required ────────────────────────────────────────────────────────────────

# Your iCloud email address (the one you use to sign in to Apple ID)
ICLOUD_EMAIL=your_name@icloud.com

# App-specific password generated at https://appleid.apple.com
# → Security → App passwords → Generate a password
# Use your Apple ID password here is a SECURITY RISK — always use app-specific.
ICLOUD_APP_PASSWORD=xxxx-xxxx-xxxx-xxxx

# ── Optional (iCloud defaults shown) ────────────────────────────────────────

# IMAP_HOST=imap.mail.me.com
# IMAP_PORT=993
# IMAP_SSL=true
