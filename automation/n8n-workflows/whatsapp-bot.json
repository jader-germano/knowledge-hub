          "jsCode": "const d=$input.first().json;\nconst t=(d.text||'').toLowerCase();\nconst sig=['obrigado','obrigada','valeu','ate mais','tchau','bye','goodbye','thank you','thanks','see you','nao tenho interesse','no thanks','vou pensar','combinado','falaremos','agendaremos'];\nconst done=sig.some(s=>t.includes(s));\nconst body='<html><body style=\"font-family:Arial;max-width:600px;margin:0 auto\"><h2 style=\"color:#075e54\">WhatsApp Bot - Resumo</h2><p><b>Contato:</b> '+d.senderName+' (+'+d.from+')</p><p><b>Categoria:</b> '+d.category+'</p><p><b>Horario:</b> '+d.timestamp+'</p><hr><h3>Mensagem recebida:</h3><div style=\"background:#dcf8c6;padding:12px;border-radius:8px\">'+d.text+'</div><h3>Resposta enviada:</h3><div style=\"background:#f0f0f0;padding:12px;border-radius:8px\">'+d.replyText+'</div><hr><p style=\"color:#888;font-size:11px\">Gerado pelo assistente do Philipe</p></body></html>';\nreturn [{ json:{ ...d, conversationDone:done, emailSubject:'[WA Bot] Conversa - '+d.senderName+' ('+d.category+')', emailBody:body }}];"
        },
