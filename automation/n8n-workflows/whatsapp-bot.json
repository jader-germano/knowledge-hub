        "id": "n000",
        "name": "WhatsApp Trigger",
        "type": "n8n-nodes-base.whatsappTrigger",
        "typeVersion": 1,
        "position": [
          208,
          304
        ],
        "webhookId": "wh-philipe-chatbot-v1"
