          "jsCode": "const m = $json;\nreturn [{ json: {\n  ...m,\n  openai_classify: {\n    model:\"gpt-4o-mini\",\n    messages:[\n      { role:\"system\", content:\"Classifique e retorne APENAS JSON: {\\\"category\\\":\\\"recruitment|product_service|personal_urgent|personal_normal\\\",\\\"reason\\\":\\\"explicacao\\\"}\\n\\n- recruitment: emprego, vaga, recrutamento, headhunter\\n- product_service: compra, venda, orcamento, produto, servico\\n- personal_urgent: emergencia, urgente, hospital, acidente\\n- personal_normal: conversa pessoal rotineira\\n\\nApenas JSON puro.\" },\n      { role:\"user\", content:\"De: \"+m.senderName+\"\\nMsg: \"+m.text }\n    ],\n    max_tokens:120, temperature:0.1\n  }\n}}];"
