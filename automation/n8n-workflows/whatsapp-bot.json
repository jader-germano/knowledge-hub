      {
        "parameters": {
          "jsCode": "// HMAC-SHA256 Webhook Signature Validation\nconst crypto = require('crypto');\n\nconst webhookSecret = $env.WHATSAPP_WEBHOOK_SECRET;\nif (!webhookSecret) {\n  throw new Error('Security: WHATSAPP_WEBHOOK_SECRET env variable not configured');\n}\n\nconst signature = $request?.headers?.['x-hub-signature-256'];\nif (!signature) {\n  throw new Error('Security Violation: Missing x-hub-signature-256 header');\n}\n\nconst rawBody = JSON.stringify($input.first().json);\nconst expectedSignature = 'sha256=' + crypto.createHmac('sha256', webhookSecret).update(rawBody).digest('hex');\n\nif (signature !== expectedSignature) {\n  throw new Error('Security Violation: Invalid webhook signature');\n}\n\nreturn $input.all();"
        },
        "id": "n100",
        "name": "Validate Webhook Signature",
        "type": "n8n-nodes-base.code",
        "typeVersion": 2,
        "position": [
          320,
          304
        ],
        "alwaysOutputData": false
      },
      {
        "parameters": {
          "jsCode": "// Rate Limiting: max 5 messages per minute per user\nconst raw = $input.first().json;\nconst changes = raw.entry?.[0]?.changes?.[0];\nconst value = changes?.value;\nconst messages = value?.messages;\nif (!messages || !messages.length) return [];\nconst msg = messages[0];\nconst userId = msg.from;\n\n// Use staticData for rate limit tracking\nconst staticData = $getWorkflowStaticData('global');\nif (!staticData.rateLimits) staticData.rateLimits = {};\n\nconst now = Date.now();\nconst windowMs = 60000; // 1 minute\nconst maxMessages = 5;\n\n// Clean old entries\nif (staticData.rateLimits[userId]) {\n  staticData.rateLimits[userId] = staticData.rateLimits[userId].filter(ts => now - ts < windowMs);\n}\n\nconst userHits = staticData.rateLimits[userId] || [];\n\nif (userHits.length >= maxMessages) {\n  throw new Error(`Rate limit exceeded for user ${userId}: ${userHits.length} messages in last minute`);\n}\n\nuserHits.push(now);\nstaticData.rateLimits[userId] = userHits;\n\nreturn $input.all();"
        },
        "id": "n101",
        "name": "Rate Limit Check",
        "type": "n8n-nodes-base.code",
        "typeVersion": 2,
        "position": [
          520,
          304
        ],
        "alwaysOutputData": false
      },
      {
        "parameters": {
          "jsCode": "// Configuracoes via environment variables\nconst raw = $input.first().json;\nreturn [{ json: {\n  _raw: raw,\n  CONFIG: {\n    OLLAMA_URL:        $env.OLLAMA_BASE_URL || 'http://100.68.217.36:11434/v1/chat/completions',\n    OLLAMA_MODEL:      $env.OLLAMA_MODEL || 'qwen2.5-coder:7b',\n    NIM_URL:           $env.NIM_BASE_URL || 'https://integrate.api.nvidia.com/v1/chat/completions',\n    NIM_KEY:           $env.NIM_API_KEY || '',\n    NIM_MODEL:         $env.NIM_MODEL || 'nvidia/llama-3.3-nemotron-super-49b-v1.5',\n    WA_ACCESS_TOKEN:   $env.WHATSAPP_ACCESS_TOKEN || '',\n    PUSHOVER_TOKEN:    $env.PUSHOVER_APP_TOKEN || '',\n    PUSHOVER_USER_KEY: $env.PUSHOVER_USER_KEY || '',\n    OWNER_EMAIL:       $env.OWNER_EMAIL || 'jader@jpglabs.com.br'\n  }\n}}];"
        },
        "id": "n001",
        "name": "Configuracoes",
        "type": "n8n-nodes-base.code",
        "typeVersion": 2,
        "position": [
          720,
          304
        ],
        "alwaysOutputData": false
      },
      {
        "parameters": {
          "jsCode": "const raw = $json._raw;\nconst changes = raw.entry?.[0]?.changes?.[0];\nconst value = changes?.value;\nconst messages = value?.messages;\nif (!messages || !messages.length) return [];\nconst msg = messages[0];\n\n// Handle unrecognized message types\nconst supportedTypes = ['text'];\nif (!supportedTypes.includes(msg.type)) {\n  // Route to unrecognized type handler\n  return [{ json: {\n    CONFIG: $json.CONFIG,\n    _unrecognizedType: true,\n    messageType: msg.type,\n    from: msg.from,\n    senderName: value.contacts?.[0]?.profile?.name || msg.from,\n    timestamp: new Date(parseInt(msg.timestamp)*1000).toISOString(),\n    phoneNumberId: value.metadata.phone_number_id\n  }}];\n}\n\nif (!value.contacts?.length) return [];\nconst contact = value.contacts[0];\nreturn [{ json: {\n  CONFIG: $json.CONFIG,\n  _unrecognizedType: false,\n  messageId: msg.id,\n  from: msg.from,\n  senderName: contact?.profile?.name || msg.from,\n  text: msg.text.body,\n  timestamp: new Date(parseInt(msg.timestamp)*1000).toISOString(),\n  phoneNumberId: value.metadata.phone_number_id,\n  displayPhoneNumber: value.metadata.display_phone_number\n}}];"
        },
