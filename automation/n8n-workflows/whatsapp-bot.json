        "parameters": {
          "jsCode": "// Log unrecognized message type for debugging\nconst m = $json;\nconsole.log(`Unrecognized message type: ${m.messageType} from ${m.from} at ${m.timestamp}`);\n\n// Send a polite reply via WhatsApp informing the user\nconst waPayload = {\n  messaging_product: 'whatsapp',\n  recipient_type: 'individual',\n  to: m.from,\n  type: 'text',\n  text: {\n    preview_url: false,\n    body: 'Desculpe, no momento consigo processar apenas mensagens de texto. Por favor, envie sua mensagem como texto. Obrigado!'\n  }\n};\n\nreturn [{ json: {\n  CONFIG: m.CONFIG,\n  from: m.from,\n  senderName: m.senderName,\n  messageType: m.messageType,\n  phoneNumberId: m.phoneNumberId,\n  wa_payload: waPayload\n}}];"
        },
